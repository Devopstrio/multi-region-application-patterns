# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Multi-Region Application Patterns Platform"

# Security
SECRET_KEY=multiregionresiliencesecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Regional Settings
CURRENT_REGION=us-east-1
PRIMARY_REGION=us-east-1
SECONDARY_REGION=eu-west-1
REGIONS=us-east-1,eu-west-1,ap-southeast-1

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=multi_region_db

# Redis / Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka / Events
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REPLICATION_TOPIC=geo.replication.events

# Traffic Routing
GLOBAL_GATEWAY_URL=https://gateway.global.local
ROUTING_STRATEGY=LATENCY # LATENCY, GEOGRAPHY, ROUND_ROBIN

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
